# Copy to backend/.env and fill in values.

# --- Database ---
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=type_a_buddy

# --- JWT ---
# IMPORTANT: change this in any non-dev environment
JWT_SECRET=dev-secret-change-me
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=1440

# --- CORS ---
# Comma-separated list
CORS_ALLOW_ORIGINS=http://localhost:19006,http://127.0.0.1:19006

# --- Password reset (6-digit code) ---
PASSWORD_RESET_CODE_EXPIRE_MINUTES=10
# In production, keep this false so the API never returns the code.
PASSWORD_RESET_RETURN_CODE=false

# --- App / Email ---
APP_NAME=Type-A Buddy
PASSWORD_RESET_EMAIL_SUBJECT=Your password reset code

# Gmail SMTP (free Gmail account)
# 1) Enable 2-Step Verification on the Google account
# 2) Create an App Password (NOT your normal Gmail password)
# 3) Use the app password as SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_SSL=false
SMTP_USER=aiplanningapp@gmail.com
SMTP_PASSWORD=PASTE_GMAIL_APP_PASSWORD_HERE
SMTP_FROM=aiplanningapp@gmail.com
